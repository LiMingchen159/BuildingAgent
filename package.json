{
  "name": "building-agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/api",
    "apps/cli",
    "apps/web"
  ],
  "scripts": {
    "dev": "npm --workspace @building-agent/api run dev",
    "dev:api": "npm --workspace @building-agent/api run dev",
    "dev:web": "npm --workspace @building-agent/web run dev",
    "build": "npm --workspaces --if-present run build",
    "test": "node scripts/run-tests.cjs",
    "typecheck": "npm --workspaces --if-present run typecheck",
    "smoke": "node scripts/smoke-local.cjs"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
