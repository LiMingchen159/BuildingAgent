    {
      "id": "milestone:M003",
      "label": "M003: Building Operations Workflow Prototypes",
      "type": "milestone",
      "confidence": "EXTRACTED",
      "sourceFile": "milestones/M003/M003-ROADMAP.md"
    },
    {
      "id": "decision:M001:1",
      "label": "Chose an npm workspace monorepo with a TypeScript Fastify API, Vite React Web UI, and TypeScript CLI so the local platform can be verified through shared root scripts while preserving separate entrypoint boundaries.",
      "type": "decision",
      "description": "Source: S01-SUMMARY.md/Key decisions; S03-SUMMARY.md/Key decisions",
      "confidence": "EXTRACTED",
      "sourceFile": "milestones/M001/M001-LEARNINGS.md"
    },
    {
      "id": "decision:M001:2",
      "label": "Chose backend-side bearer auth, selected-project state, project membership, and permission checks as the source of truth for all protected Web/API/CLI/provider operations rather than trusting browser or CLI state.",
      "type": "decision",
      "description": "Source: S01-SUMMARY.md/Patterns established; S04-SUMMARY.md/Key decisions",
      "confidence": "EXTRACTED",
      "sourceFile": "milestones/M001/M001-LEARNINGS.md"
    },
    {
      "id": "decision:M001:3",
      "label": "Chose bounded authenticated placeholder registry and project-management APIs with `placeholderOnly`, `limit`, and `requestId` metadata so future runtime/tool/skill/gateway/building-domain surfaces are visible without becoming live integrations.",
      "type": "decision",
      "description": "Source: S02-SUMMARY.md/Key decisions",
      "confidence": "EXTRACTED",
      "sourceFile": "milestones/M001/M001-LEARNINGS.md"
    },
    {
      "id": "decision:M001:4",
      "label": "Chose a backend provider ports-and-adapters seam that prefers configured OpenAI-compatible providers and uses deterministic mock fallback for no-secret local/CI/smoke runs.",
      "type": "decision",
      "description": "Source: S04-SUMMARY.md/Key decisions",
      "confidence": "EXTRACTED",
      "sourceFile": "milestones/M001/M001-LEARNINGS.md"
    },
    {
      "id": "decision:M001:5",
      "label": "Chose to make the M001 validation artifact and requirements matrix the closure source of truth for validated, skeleton-only, deferred, and out-of-scope claims.",
      "type": "decision",
      "description": "Source: S05-SUMMARY.md/Key decisions",
      "confidence": "EXTRACTED",
      "sourceFile": "milestones/M001/M001-LEARNINGS.md"
    },
    {
      "id": "decision:M001:6",
      "label": "The auth/session/project boundary had to land first because registry, CLI, smoke, and provider-backed chat all reuse the same `userId`, `projectId`, and `permissions` contract.",
      "type": "decision",
      "description": "Source: S01-SUMMARY.md/What Happened",
      "confidence": "EXTRACTED",
      "sourceFile": "milestones/M001/M001-LEARNINGS.md"
    },
    {
      "id": "decision:M001:7",
      "label": "Placeholder surfaces are easy to overclaim unless the artifacts repeatedly state that gateway, building-domain, tool, and skill surfaces are synthetic inspections rather than live integrations.",
      "type": "decision",
      "description": "Source: M001-VALIDATION.md/Requirement coverage matrix",
      "confidence": "EXTRACTED",
      "sourceFile": "milestones/M001/M001-LEARNINGS.md"
    },
    {
      "id": "decision:M001:8",
      "label": "A smoke check that uses the built CLI against live API/Web services gives stronger platform evidence than unit tests alone because it catches startup, config, auth persistence, request-id diagnostics, and cleanup behavior together.",
      "type": "decision",
      "description": "Source: S03-SUMMARY.md/What Happened",
      "confidence": "EXTRACTED",
      "sourceFile": "milestones/M001/M001-LEARNINGS.md"
    },
    {
      "id": "decision:M001:9",
      "label": "Real-provider-first architecture can still be safe for local verification if live-provider calls are env-gated and default smoke asserts deterministic fallback metadata rather than requiring secrets.",
      "type": "decision",
      "description": "Source: S04-SUMMARY.md/Verification",
      "confidence": "EXTRACTED",
      "sourceFile": "milestones/M001/M001-LEARNINGS.md"
    },
    {
      "id": "decision:M001:10",
      "label": "Requirement wording must be reconciled after implementation because early broad requirements can imply production runtime, real dispatcher, or real analytics scope that the local skeleton did not and should not claim.",
      "type": "decision",
      "description": "Source: S05-SUMMARY.md/What Happened",
      "confidence": "EXTRACTED",
      "sourceFile": "milestones/M001/M001-LEARNINGS.md"
    },
    {
      "id": "decision:M001:11",
      "label": "Reuse canonical request-id-bearing API error envelopes across Web and CLI so future agents can diagnose auth, project, malformed payload, provider, and service availability failures without secret exposure.",
      "type": "decision",
      "description": "Source: S01-SUMMARY.md/Patterns established; S03-SUMMARY.md/Patterns established",
      "confidence": "EXTRACTED",
      "sourceFile": "milestones/M001/M001-LEARNINGS.md"
    },
    {
      "id": "decision:M001:12",
      "label": "Put provider invocation behind backend auth, selected-project, membership, and permission guards; clients should render provider metadata but never own provider selection or secrets.",
      "type": "decision",
      "description": "Source: S04-SUMMARY.md/Patterns established",
      "confidence": "EXTRACTED",
      "sourceFile": "milestones/M001/M001-LEARNINGS.md"
    },
    {
      "id": "decision:M001:13",
      "label": "Parse API payloads strictly at Web/CLI boundaries and fail closed with `api_malformed` rather than silently rendering partial or unexpected placeholder data.",
      "type": "decision",
      "description": "Source: S02-SUMMARY.md/Patterns established; S03-SUMMARY.md/Key decisions",
      "confidence": "EXTRACTED",
      "sourceFile": "milestones/M001/M001-LEARNINGS.md"
    },
    {
      "id": "decision:M001:14",
      "label": "Treat `npm run smoke` as the authoritative local coherence check and make its output agent-readable with stage markers, request ids, child exit codes, fallback assertions, and cleanup logs.",
      "type": "decision",
      "description": "Source: S03-SUMMARY.md/Observability surfaces; M001-VALIDATION.md/Operational verification",
      "confidence": "EXTRACTED",
      "sourceFile": "milestones/M001/M001-LEARNINGS.md"
    },
    {
      "id": "decision:M001:15",
      "label": "Use requirements and validation artifacts as a closure record that explicitly separates proven local skeleton behavior, skeleton-only contracts, deferred work, and negative boundaries.",
      "type": "decision",
      "description": "Source: S05-SUMMARY.md/Patterns established",
      "confidence": "EXTRACTED",
      "sourceFile": "milestones/M001/M001-LEARNINGS.md"
    },
    {
      "id": "decision:M001:16",
      "label": "The workspace package did not expose the CLI as a linked `@building-agent/cli` binary in this install, so smoke had to use the verified emitted build artifact path.",
      "type": "decision",
      "description": "Source: S03-SUMMARY.md/Deviations",
      "confidence": "EXTRACTED",
      "sourceFile": "milestones/M001/M001-LEARNINGS.md"
    },
    {
      "id": "decision:M001:17",
      "label": "Closure review surfaced that Web project-management responses should validate `projectId` exactly against the requested id before real integrations land.",
      "type": "decision",
      "description": "Source: S02-SUMMARY.md/Known Limitations",
      "confidence": "EXTRACTED",
      "sourceFile": "milestones/M001/M001-LEARNINGS.md"
    },
    {
      "id": "decision:M001:18",
      "label": "Final validation required a remediation-round operational rerun to prove smoke and README command coverage freshly at milestone closure, not just from prior slice evidence.",
      "type": "decision",
      "description": "Source: M001-VALIDATION.md/Verification classes",
      "confidence": "EXTRACTED",
