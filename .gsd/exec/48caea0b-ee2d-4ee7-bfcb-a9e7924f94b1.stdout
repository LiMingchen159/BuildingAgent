118: const API_BASE_URL = import.meta.env.VITE_API_BASE_URL ?? "";
119: const REQUEST_TIMEOUT_MS = 8000;
120: const PLACEHOLDER_STATUSES = new Set(["placeholder", "mock", "not_configured"]);
121: const RUNTIME_KINDS = new Set(["llm", "embedding", "workflow"]);
122: const TOOL_CATEGORIES = new Set(["analysis", "retrieval", "building"]);
123: const SKILL_DOMAINS = new Set(["building", "project", "runtime"]);
124: const GATEWAY_PROTOCOLS = new Set(["http", "mcp", "local"]);
125: const CAPABILITY_DOMAINS = new Set(["energy", "safety", "maintenance", "planning"]);
126: 
127: function apiUrl(path: string): string {
128:   return `${API_BASE_URL}${path}`;
129: }
130: 
131: function isRecord(value: unknown): value is Record<string, unknown> {
132:   return typeof value === "object" && value !== null && !Array.isArray(value);
133: }
134: 
135: function isStringIn<T extends string>(value: unknown, allowed: Set<string>): value is T {
136:   return typeof value === "string" && allowed.has(value);
137: }
138: 
139: function parseApiError(value: unknown): ApiErrorDetail | null {
140:   if (!isRecord(value) || !isRecord(value.error)) {
141:     return null;
142:   }
143:   const { code, message, requestId } = value.error;
144:   if (typeof code !== "string" || typeof message !== "string") {
145:     return null;
146:   }
147:   return { code, message, requestId: typeof requestId === "string" ? requestId : undefined };
148: }
149: 
150: function malformed(message = "The API returned an unreadable response."): ApiClientError {
151:   return new ApiClientError({ code: "api_malformed", message });
152: }
153: 
154: function unavailable(): ApiClientError {
155:   return new ApiClientError({ code: "api_unavailable", message: "Local API is unavailable. Check that the API dev server is running, then retry." });
156: }
157: 
158: async function readJson(response: Response): Promise<unknown> {
159:   try {
160:     return await response.json();
161:   } catch {
162:     throw malformed();
163:   }
164: }
165: 
166: async function requestJson(path: string, options: RequestInit = {}): Promise<unknown> {
167:   const controller = new AbortController();
168:   const timeoutId = window.setTimeout(() => controller.abort(), REQUEST_TIMEOUT_MS);
169: 
170:   try {
171:     const headers = new Headers(options.headers);
172:     if (options.body !== undefined && !headers.has("content-type")) {
173:       headers.set("content-type", "application/json");
174:     }
175: 
176:     const response = await fetch(apiUrl(path), {
177:       ...options,
178:       headers,
179:       signal: controller.signal
180:     });
181:     const payload = await readJson(response);
182:     if (!response.ok) {
183:       const detail = parseApiError(payload) ?? { code: "api_malformed", message: "The API returned an error in an unexpected format." };
184:       throw new ApiClientError(detail, response.status);
185:     }
186:     return payload;
187:   } catch (error) {
188:     if (error instanceof ApiClientError) {
189:       throw error;
190:     }
191:     throw unavailable();
192:   } finally {
193:     window.clearTimeout(timeoutId);
194:   }
195: }
196: 
197: function authHeaders(token: string): HeadersInit {
198:   const headers = new Headers();
199:   headers.set("authorization", `Bearer ${token}`);
200:   return headers;
201: }
202: 
203: function hasPlaceholderBase(value: Record<string, unknown>): value is Record<string, unknown> & PlaceholderBase {
204:   return typeof value.id === "string" && typeof value.name === "string" && typeof value.description === "string" && isStringIn<PlaceholderStatus>(value.status, PLACEHOLDER_STATUSES
205: }
206: 
207: function parseRuntimeProvider(value: unknown): RuntimeProviderSummary | null {
208:   if (!isRecord(value) || !hasPlaceholderBase(value) || !isStringIn<RuntimeProviderSummary["kind"]>(value.kind, RUNTIME_KINDS)) {
209:     return null;
210:   }
211:   return { id: value.id, name: value.name, status: value.status, description: value.description, kind: value.kind };
212: }
213: 
214: function parseTool(value: unknown): ToolSummary | null {
215:   if (!isRecord(value) || !hasPlaceholderBase(value) || !isStringIn<ToolSummary["category"]>(value.category, TOOL_CATEGORIES)) {
216:     return null;
217:   }
218:   return { id: value.id, name: value.name, status: value.status, description: value.description, category: value.category };
219: }
