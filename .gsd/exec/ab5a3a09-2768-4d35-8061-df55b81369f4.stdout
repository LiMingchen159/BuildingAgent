Root files:
./apps/api/package.json
./apps/api/tsconfig.json
./apps/web/index.html
./apps/web/package.json
./apps/web/tsconfig.json
./apps/web/vite.config.ts
./scripts/run-api-tests.cjs
./scripts/run-tests.cjs

Package scripts:
{
  "dev": "npm --workspace @building-agent/api run dev",
  "dev:api": "npm --workspace @building-agent/api run dev",
  "dev:web": "npm --workspace @building-agent/web run dev",
  "build": "npm --workspaces --if-present run build",
  "test": "node scripts/run-tests.cjs",
  "typecheck": "npm --workspaces --if-present run typecheck"
}
apps/api {
  "dev": "tsx watch src/index.ts",
  "build": "tsc -p tsconfig.json",
  "test": "vitest run",
  "typecheck": "tsc -p tsconfig.json --noEmit"
}
apps/web {
  "dev": "vite --host 127.0.0.1",
  "build": "tsc -p tsconfig.json && vite build",
  "test": "vitest run",
  "typecheck": "tsc -p tsconfig.json --noEmit"
}
