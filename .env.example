HOST=127.0.0.1
PORT=3000
VITE_API_BASE_URL=http://127.0.0.1:3000

# LLM provider config. Leave the key empty to use the deterministic mock fallback.
BUILDING_AGENT_LLM_PROVIDER=openai-compatible
BUILDING_AGENT_LLM_API_KEY=
BUILDING_AGENT_LLM_BASE_URL=https://api.openai.com/v1
BUILDING_AGENT_LLM_MODEL=gpt-4o-mini
BUILDING_AGENT_LLM_ALLOW_FALLBACK=true

# Existing local aliases are also supported:
# LLM_API_KEY=
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o-mini

# Optional override for the local Knowledge Base folder.
BUILDING_AGENT_KNOWLEDGE_BASE_DIR=Knowledge Base

# Embedding for hybrid site-rule retrieval (FTS + vector). Reindex after model changes.
# If unset, reuses BUILDING_AGENT_LLM_API_KEY / BUILDING_AGENT_LLM_BASE_URL and text-embedding-3-small.
# BUILDING_AGENT_EMBEDDING_API_KEY=
# BUILDING_AGENT_EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# BUILDING_AGENT_EMBEDDING_MODEL=text-embedding-v3

# Element chiller — BMS-database catalog + enteliWEB live (demo defaults in code if unset)
# BMS_DATABASE_API_URL=http://127.0.0.1:8765
# ELEMENT_ENTELI_BASE_URL=http://223.197.33.165:20800/enteliweb
# ELEMENT_ENTELI_USERNAME=
# ELEMENT_ENTELI_PASSWORD=
