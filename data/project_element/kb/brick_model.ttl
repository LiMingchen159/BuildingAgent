bldg:Total_Harmonic_Distortion_Sensor a owl:Class ;
    rdfs:label "Total Harmonic Distortion Sensor" ;
    rdfs:comment "Project-specific class for THDAMP/THDV points. The local Brick taxonomy has no dedicated Total Harmonic Distortion point class; this class is modeled as a subclass of brick:Sensor." ;
    rdfs:subClassOf brick:Sensor ;
    brick:hasQuantity quantitykind:DimensionlessRatio .

