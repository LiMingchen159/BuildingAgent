quantitykind:DimensionlessRatio a qudt:QuantityKind .

bldg:HX_BF_Heat_Exchanger_Group a brick:Heat_Exchanger ;
    rdfs:label "HX-BF Heat Exchanger Group" ;
    brick:feeds bldg:Main_Condenser_Water_Loop ;
    brick:isFedBy bldg:Sea_Water_Loop .

bldg:Sea_Water_Loop a brick:Water_Loop ;
    rdfs:label "Sea Water Loop" ;
    brick:feeds bldg:HX_BF_Heat_Exchanger_Group ;
    brick:isFedBy bldg:SWP_01,
        bldg:SWP_02,
        bldg:SWP_03,
        bldg:SWP_04,
        bldg:SWP_05 .

bldg:Coefficient_Of_Performance_Sensor a owl:Class ;
    rdfs:label "Coefficient Of Performance Sensor" ;
    rdfs:comment "Project-specific class for chiller COP points. The local Brick taxonomy has no dedicated coefficient-of-performance point class; this class is modeled as a subclass of brick:Sensor." ;
    rdfs:subClassOf brick:Sensor ;
    brick:hasQuantity quantitykind:DimensionlessRatio .

bldg:Total_Compressor_Starts_Sensor a owl:Class ;
    rdfs:label "Total Compressor Starts Sensor" ;
    rdfs:comment "Project-specific class for cumulative compressor-start count points. The local Brick taxonomy has no dedicated compressor-start count point class; this class is modeled as a subclass of brick:Sensor." ;
    rdfs:subClassOf brick:Sensor ;
    brick:hasQuantity quantitykind:Dimensionless .

bldg:Main_Condenser_Water_Loop a brick:Condenser_Water_Loop ;
    rdfs:label "Main Condenser Water Loop" ;
    brick:feeds bldg:WCC_01,
        bldg:WCC_02,
        bldg:WCC_03,
        bldg:WCC_04,
        bldg:WCC_05,
        bldg:WCC_06,
        bldg:WCC_07,
        bldg:WCC_08 ;
    brick:isFedBy bldg:HX_BF_Heat_Exchanger_Group .

bldg:Main_Chilled_Water_Loop a brick:Chilled_Water_Loop ;
    rdfs:label "Main Chilled Water Loop" ;
    brick:feeds bldg:Building_Chilled_Water_Load,
        bldg:Ice_Rink_Chiller_Plant ;
    brick:isFedBy bldg:CHP_1P_01,
        bldg:CHP_1P_02,
        bldg:CHP_1P_03,
        bldg:CHP_1P_04,
        bldg:CHP_1P_05,
        bldg:CHP_1P_06,
        bldg:CHP_1P_07,
        bldg:CHP_1P_08,
        bldg:CHP_1P_09,
        bldg:CHP_1P_10,
        bldg:WCC_01,
        bldg:WCC_02,
        bldg:WCC_03,
        bldg:WCC_04,
        bldg:WCC_05,
        bldg:WCC_06,
        bldg:WCC_07,
        bldg:WCC_08 .

bldg:Ice_Rink_Chiller_Plant a brick:Chilled_Water_System ;
    rdfs:label "Ice Rink Chiller Plant" ;
    brick:hasPoint bldg:Ice_Rink_Chiller_Plant__IR_CP_01_CWRT,
        bldg:Ice_Rink_Chiller_Plant__IR_CP_01_CWST,
        bldg:Ice_Rink_Chiller_Plant__IR_CP_01_ESTOP,
        bldg:Ice_Rink_Chiller_Plant__IR_CP_01_PWR,
        bldg:Ice_Rink_Chiller_Plant__IR_CP_01_RPRESS,
        bldg:Ice_Rink_Chiller_Plant__IR_CP_01_S,
        bldg:Ice_Rink_Chiller_Plant__IR_CP_01_SPRESS,
        bldg:Ice_Rink_Chiller_Plant__IR_CP_01_TALM,
        bldg:Ice_Rink_Chiller_Plant__IR_CP_02_CWRT,
